<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop">
	<id>dev.geopjr.Calligraphy</id>
	<metadata_license>CC0-1.0</metadata_license>
	<project_license>GPL-3.0-or-later</project_license>
	<name translate="yes">Calligraphy</name>
	<developer id="dev.geopjr">
		<name translate="no">Evangelos "GeopJr" Paterakis</name>
	</developer>
	<summary>Turn text into ASCII banners</summary>
	<description>
		<p>
			Calligraphy turns short texts into large, impressive banners made up of ASCII Characters, ready to be copied or exported to images.
			Spice up your online conversations by adding some extra oompf to your messages!
		</p>
	</description>
	<requires>
		<internet>offline-only</internet>
		<display_length compare="ge">360</display_length>
	</requires>
	<recommends>
		<control>pointing</control>
		<control>keyboard</control>
		<control>touch</control>
	</recommends>
	<screenshots>
		<screenshot type="default">
			<image>https://codeberg.org/GeopJr/Calligraphy/media/commit/c511d385b8c7e15da5014914841f139b87b99c32/data/screenshots/entry.png</image>
			<!--translators: This is a screenshot caption-->
			<caption>Entry</caption>
		</screenshot>
		<screenshot>
			<image>https://codeberg.org/GeopJr/Calligraphy/media/commit/c511d385b8c7e15da5014914841f139b87b99c32/data/screenshots/search.png</image>
			<!--translators: This is a screenshot caption-->
			<caption>Search</caption>
		</screenshot>
		<screenshot>
			<image>https://codeberg.org/GeopJr/Calligraphy/media/commit/c511d385b8c7e15da5014914841f139b87b99c32/data/screenshots/detailed-view.png</image>
			<!--translators: This is a screenshot caption-->
			<caption>Detailed View</caption>
		</screenshot>
	</screenshots>
	<launchable type="desktop-id">dev.geopjr.Calligraphy.desktop</launchable>
	<translation type="gettext">dev.geopjr.Calligraphy</translation>
	<url type="homepage">https://calligraphy.geopjr.dev/</url>
	<url type="bugtracker">https://codeberg.org/GeopJr/Calligraphy/issues</url>
	<url type="donation">https://geopjr.dev/donate</url>
	<url type="vcs-browser">https://codeberg.org/GeopJr/Calligraphy</url>
	<url type="contribute">https://codeberg.org/GeopJr/Calligraphy#contributing</url>
	<content_rating type="oars-1.1" />
	<provides>
		<binary>dev.geopjr.Calligraphy</binary>
	</provides>
	<releases translate="no">
		<release translate="no" version="1.2.0" date="2025-03-22">
			<description translate="no">
				<ul>
					<li>Visual refinements to match the state of the art of GNOME apps</li>
					<li>Updated translations</li>
				</ul>
			</description>
		</release>
		<release translate="no" version="1.1.0" date="2025-01-21">
			<description translate="no">
				<ul>
					<li>Added the ability to star fonts</li>
					<li>Other minor bug fixes and improvements</li>
				</ul>
			</description>
		</release>
		<release translate="no" version="1.0.2" date="2024-10-01">
			<description translate="no">
				<ul>
					<li>Fixed window grabbing being activated when trying to select text</li>
				</ul>
			</description>
		</release>
		<release translate="no" version="1.0.1" date="2024-05-25">
			<description translate="no">
				<ul>
					<li>Accessibility improvements</li>
					<li>Fixed metadata</li>
				</ul>
			</description>
		</release>
		<release translate="no" version="1.0.0" date="2024-05-25">
			<description translate="no">
				<p>
					This is a fork of the original Calligraphy after its archival with the following changes:
				</p>
				<ul>
					<li>Switched to GridView for displaying all the fonts with the ability to display and update unlimited fonts with no performance impact</li>
					<li>Accessibility improvements</li>
					<li>Added exporting to png support</li>
					<li>Added toggling wrapping support</li>
					<li>Other visual changes</li>
					<li>Many other optimizations</li>
				</ul>
			</description>
		</release>
	</releases>
	<kudos>
		<!--
				GNOME Software kudos:
				https://gitlab.gnome.org/GNOME/gnome-software/blob/master/doc/kudos.md
			-->
		<kudo>ModernToolkit</kudo>
		<kudo>HiDpiIcon</kudo>
	</kudos>
	<branding>
		<color type="primary" scheme_preference="light">#bdadff</color>
		<color type="primary" scheme_preference="dark">#443972</color>
	</branding>
</component>
