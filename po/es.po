msgid "Turn text into ASCII banners"
msgstr "Convierta texto en pancartas ASCII"

#. Translators: These are search terms for the application;
#. the translation should contain the original list AND the translated strings.
#. The list must end with a semicolon.
#: data/dev.geopjr.Calligraphy.desktop.in:14
msgid "ascii;convert;conversion;text;"
msgstr "ascii;convert;conversion;text;convertir;conversión;texto;"

#: data/dev.geopjr.Calligraphy.appdata.xml.in:12
msgid ""
"Calligraphy turns short texts into large, impressive banners made up of "
"ASCII Characters. Spice up your online conversations by adding some extra "
"oompf to your messages!"
msgstr ""
"Calligraphy convierte textos breves en pancartas grandes e impresionantes "
"hechas de caracteres ASCII. ¡Anime sus conversaciones en línea añadiendo un "
"poco más de entusiasmo a sus mensajes!"

